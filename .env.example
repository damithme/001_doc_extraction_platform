# ── LLM APIs ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Observability (optional) ───────────────────────────────
# Get a free key at https://smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=docmind

# ── Infrastructure ─────────────────────────────────────────
# Local dev (docker-compose up -d qdrant postgres redis)
QDRANT_URL=http://localhost:6333
POSTGRES_DSN=postgresql://docmind:docmind@localhost:5432/docmind
REDIS_URL=redis://localhost:6379

# Note: when running via docker-compose up --build (full stack),
# the api and worker services override these with internal service names:
#   QDRANT_URL=http://qdrant:6333
#   POSTGRES_DSN=postgresql://docmind:docmind@postgres:5432/docmind
#   REDIS_URL=redis://redis:6379